# dz-dashboard configuration. Copy to .env and adjust if your Phase 1 checkout
# is not the sibling ../danger-zone. The dashboard needs NO secrets.

# The live Phase 1 SQLite database, read-only. Absolute path recommended so the
# server reads the same file regardless of where it is launched.
# Default (if unset): ../danger-zone/data/fantasy.db
# DATABASE_URL=sqlite:////home/mainuser/danger-zone/data/fantasy.db

# API bind address (the SPA's dev proxy expects 8800).
# DASHBOARD_HOST=127.0.0.1
# DASHBOARD_PORT=8800

# Origins allowed to call the API (the Vite dev server).
# DASHBOARD_CORS_ORIGINS=["http://127.0.0.1:5173","http://localhost:5173"]

# LOG_LEVEL=INFO
